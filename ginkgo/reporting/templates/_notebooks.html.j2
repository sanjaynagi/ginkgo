{% if report.notebooks %}
<h2 id="notebooks"><span class="num">07</span>Notebooks</h2>
{% for card in report.notebooks %}
<div class="notebook-card">
  <div class="notebook-icon">nb</div>
  <div class="notebook-meta">
    <div class="title">{{ card.title }}</div>
    <div class="sub">{{ card.sub_line }}</div>
  </div>
  <a class="link" href="{{ card.link_relpath }}">open →</a>
</div>
{% endfor %}
{% endif %}
